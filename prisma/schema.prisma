generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["linux-musl-arm64-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IntegrationFamily {
  PROMOSTANDARDS
  CUSTOM
}

enum VendorType {
  SUPPLIER
  DECORATOR
}

enum MappingProtocol {
  SOAP
  REST
  RPC
  XML
  JSON
}

enum MappingPayloadFormat {
  JSON
  XML
}

enum SyncScope {
  MAPPING
  ALL
}

enum SyncRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum IntegrationJobKind {
  CATALOG_SYNC
  ORDER_SUBMISSION
  ORDER_STATUS_POLL
  ORDER_SHIPMENT_POLL
  ORDER_INVOICE_POLL
  ORDER_REMITTANCE_SUBMISSION
}

enum IntegrationJobStatus {
  PENDING
  ENQUEUED
  RUNNING
  CANCEL_REQUESTED
  SUCCEEDED
  FAILED
  DEAD_LETTERED
  CANCELLED
}

enum OperatorTraceCategory {
  VENDOR_API
  BIGCOMMERCE_API
  INTERNAL_FAILURE
}

enum OrderLifecycleStatus {
  PENDING_SUBMISSION
  SUBMISSION_QUEUED
  SUBMITTED
  ISSUE
  PARTIALLY_SHIPPED
  SHIPPED
  INVOICED
  COMPLETED
  FAILED
  CANCELLED
}

enum PendingRelatedLinkStatus {
  PENDING
  RESOLVED
  FAILED
}

enum EnrichmentSource {
  PRICING
  INVENTORY
  MEDIA
}

enum EnrichmentRetryStatus {
  PENDING
  RETRYING
  RESOLVED
  FAILED
}

model User {
  user_id  Int     @id
  email    String
  username String?

  @@map("user")
}

model Store {
  store_id       Int     @id @default(autoincrement())
  store_hash     String  @unique @db.VarChar(10)
  access_token   String?
  scope          String?
  markup_percent Int?

  @@map("store")
}

model StoreUser {
  store_user_id Int      @id @default(autoincrement())
  user_id       Int
  store_hash    String   @db.VarChar(10)
  is_admin      Boolean?

  @@unique([user_id, store_hash])
  @@map("store_user")
}

model Vendor {
  vendor_id          Int                     @id @default(autoincrement())
  vendor_name        String                  @db.VarChar(255)
  vendor_type        VendorType              @default(SUPPLIER)
  vendor_api_url     String?                 @db.VarChar(2048)
  vendor_account_id  String?                 @db.VarChar(255)
  vendor_secret      String?
  integration_family IntegrationFamily       @default(CUSTOM)
  api_protocol       MappingProtocol?
  connection_config  Json                    @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  is_active          Boolean                 @default(true)
  datetime_added     DateTime                @default(now()) @db.Timestamptz(6)
  datetime_modified  DateTime                @default(now()) @db.Timestamptz(6)
  endpoint_mappings  VendorEndpointMapping[]
  endpoint_urls      VendorEndpointUrl[]
  sync_runs          EtlSyncRun[]
  integration_jobs   IntegrationJob[]
  product_map        VendorProductMap[]
  pending_related    PendingRelatedProductLink[]
  enrichment_retries ProductEnrichmentRetry[]
  order_integrations OrderIntegrationState[]

  @@map("vendor")
}

model EndpointMapping {
  endpoint_mapping_id    Int                     @id @default(autoincrement())
  standard_type          IntegrationFamily
  endpoint_name          String                  @db.VarChar(128)
  endpoint_version       String                  @db.VarChar(32)
  operation_name         String                  @default("") @db.VarChar(128)
  protocol               MappingProtocol         @default(SOAP)
  payload_format         MappingPayloadFormat    @default(JSON)
  is_product_endpoint    Boolean                 @default(false)
  structure_json         Json                    @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  structure_xml          String?
  request_schema         Json                    @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  response_schema        Json                    @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  transform_schema       Json                    @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  metadata               Json                    @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  created_at             DateTime                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                @default(now()) @db.Timestamptz(6)
  vendor_endpoint_links  VendorEndpointMapping[]
  vendor_endpoint_urls   VendorEndpointUrl[]
  sync_runs              EtlSyncRun[]
  integration_jobs       IntegrationJob[]
  vendor_product_records VendorProductMap[]

  @@unique([standard_type, endpoint_name, endpoint_version, operation_name])
  @@map("endpoint_mapping")
}

model VendorEndpointMapping {
  vendor_endpoint_mapping_id Int             @id @default(autoincrement())
  vendor_id                  Int
  endpoint_mapping_id        Int
  is_enabled                 Boolean         @default(true)
  runtime_config             Json            @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  created_at                 DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime        @default(now()) @db.Timestamptz(6)
  vendor                     Vendor          @relation(fields: [vendor_id], references: [vendor_id], onDelete: Cascade)
  endpoint_mapping           EndpointMapping @relation(fields: [endpoint_mapping_id], references: [endpoint_mapping_id], onDelete: Cascade)

  @@unique([vendor_id, endpoint_mapping_id])
  @@map("vendor_endpoint_mapping")
}

model VendorEndpointUrl {
  vendor_endpoint_url_id Int             @id @default(autoincrement())
  vendor_id              Int
  endpoint_mapping_id    Int
  endpoint_url           String          @db.VarChar(2048)
  created_at             DateTime        @default(now()) @db.Timestamptz(6)
  updated_at             DateTime        @default(now()) @db.Timestamptz(6)
  vendor                 Vendor          @relation(fields: [vendor_id], references: [vendor_id], onDelete: Cascade)
  endpoint_mapping       EndpointMapping @relation(fields: [endpoint_mapping_id], references: [endpoint_mapping_id], onDelete: Cascade)

  @@unique([vendor_id, endpoint_mapping_id])
  @@map("vendor_endpoint_url")
}

model EtlSyncRun {
  etl_sync_run_id    BigInt           @id @default(autoincrement())
  vendor_id          Int
  endpoint_mapping_id Int?
  sync_scope         SyncScope        @default(MAPPING)
  status             SyncRunStatus    @default(PENDING)
  started_at         DateTime         @default(now()) @db.Timestamptz(6)
  ended_at           DateTime?        @db.Timestamptz(6)
  records_read       Int              @default(0)
  records_written    Int              @default(0)
  error_message      String?
  details            Json             @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  vendor             Vendor           @relation(fields: [vendor_id], references: [vendor_id], onDelete: Cascade)
  endpoint_mapping   EndpointMapping? @relation(fields: [endpoint_mapping_id], references: [endpoint_mapping_id], onDelete: SetNull)

  @@map("etl_sync_run")
}

model IntegrationJob {
  integration_job_id        BigInt                @id @default(autoincrement())
  job_kind                  IntegrationJobKind
  vendor_id                 Int
  endpoint_mapping_id       Int?
  order_integration_state_id BigInt?
  sync_scope                SyncScope             @default(MAPPING)
  source_action             String                @db.VarChar(128)
  dedupe_key                String                @db.VarChar(512)
  correlation_id            String                @db.VarChar(128)
  request_payload           Json                  @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  status                    IntegrationJobStatus  @default(PENDING)
  attempt_count             Int                   @default(0)
  queue_message_id          String?               @db.VarChar(255)
  last_error                String?
  submitted_at              DateTime              @default(now()) @db.Timestamptz(6)
  started_at                DateTime?             @db.Timestamptz(6)
  ended_at                  DateTime?             @db.Timestamptz(6)
  vendor                    Vendor                @relation(fields: [vendor_id], references: [vendor_id], onDelete: Cascade)
  endpoint_mapping          EndpointMapping?      @relation(fields: [endpoint_mapping_id], references: [endpoint_mapping_id], onDelete: SetNull)
  events                    IntegrationJobEvent[]

  @@index([vendor_id, status])
  @@index([order_integration_state_id, status])
  @@index([dedupe_key, status])
  @@index([submitted_at])
  @@map("integration_job")
}

model OperatorTrace {
  operator_trace_id         BigInt                @id @default(autoincrement())
  category                  OperatorTraceCategory
  correlation_id            String                @db.VarChar(128)
  vendor_id                 Int?
  integration_job_id        BigInt?
  order_integration_state_id BigInt?
  etl_sync_run_id           BigInt?
  method                    String                @db.VarChar(16)
  target                    String                @db.VarChar(2048)
  action                    String                @db.VarChar(255)
  status_code               Int?
  snapshot_bucket           String?               @db.VarChar(255)
  snapshot_key              String?               @db.VarChar(1024)
  metadata                  Json                  @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  created_at                DateTime              @default(now()) @db.Timestamptz(6)

  @@index([vendor_id, created_at])
  @@index([integration_job_id, created_at])
  @@index([order_integration_state_id, created_at])
  @@index([etl_sync_run_id, created_at])
  @@index([correlation_id, created_at])
  @@map("operator_trace")
}

model IntegrationJobEvent {
  integration_job_event_id BigInt          @id @default(autoincrement())
  integration_job_id       BigInt
  event_name               String          @db.VarChar(128)
  level                    String          @db.VarChar(16)
  payload                  Json            @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  created_at               DateTime        @default(now()) @db.Timestamptz(6)
  integration_job          IntegrationJob  @relation(fields: [integration_job_id], references: [integration_job_id], onDelete: Cascade)

  @@index([integration_job_id, created_at])
  @@map("integration_job_event")
}

model OrderIntegrationState {
  order_integration_state_id   BigInt               @id @default(autoincrement())
  vendor_id                    Int
  external_order_id            String               @db.VarChar(255)
  order_source                 String               @default("BIGCOMMERCE") @db.VarChar(64)
  purchase_order_number        String               @db.VarChar(255)
  sales_order_number           String?              @db.VarChar(255)
  order_type                   String?              @db.VarChar(64)
  lifecycle_status             OrderLifecycleStatus @default(PENDING_SUBMISSION)
  status_label                 String?              @db.VarChar(255)
  status_code                  String?              @db.VarChar(64)
  shipment_status              String?              @db.VarChar(64)
  invoice_status               String?              @db.VarChar(64)
  remittance_status            String?              @db.VarChar(64)
  submission_payload           Json                 @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  latest_vendor_payload        Json                 @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  metadata                     Json                 @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  last_error                   String?
  submitted_at                 DateTime?            @db.Timestamptz(6)
  last_status_polled_at        DateTime?            @db.Timestamptz(6)
  next_status_poll_at          DateTime?            @db.Timestamptz(6)
  last_shipment_polled_at      DateTime?            @db.Timestamptz(6)
  next_shipment_poll_at        DateTime?            @db.Timestamptz(6)
  last_invoice_polled_at       DateTime?            @db.Timestamptz(6)
  next_invoice_poll_at         DateTime?            @db.Timestamptz(6)
  last_remittance_submitted_at DateTime?            @db.Timestamptz(6)
  completed_at                 DateTime?            @db.Timestamptz(6)
  created_at                   DateTime             @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime             @default(now()) @db.Timestamptz(6)
  vendor                       Vendor               @relation(fields: [vendor_id], references: [vendor_id], onDelete: Cascade)

  @@unique([vendor_id, external_order_id])
  @@unique([vendor_id, purchase_order_number])
  @@index([vendor_id, lifecycle_status])
  @@index([next_status_poll_at])
  @@index([next_shipment_poll_at])
  @@index([next_invoice_poll_at])
  @@map("order_integration_state")
}

model VendorProductMap {
  vendor_product_map_id  BigInt           @id @default(autoincrement())
  vendor_id              Int
  endpoint_mapping_id    Int?
  vendor_product_id      String?          @db.VarChar(255)
  bigcommerce_product_id BigInt?
  sku                    String           @db.VarChar(255)
  product_name           String
  last_synced_at         DateTime         @default(now()) @db.Timestamptz(6)
  metadata               Json             @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  vendor                 Vendor           @relation(fields: [vendor_id], references: [vendor_id], onDelete: Cascade)
  endpoint_mapping       EndpointMapping? @relation(fields: [endpoint_mapping_id], references: [endpoint_mapping_id], onDelete: SetNull)

  @@unique([vendor_id, sku])
  @@map("vendor_product_map")
}

model PendingRelatedProductLink {
  pending_related_product_link_id BigInt                   @id @default(autoincrement())
  vendor_id                       Int
  source_vendor_product_id        String                   @db.VarChar(255)
  target_vendor_product_id        String                   @db.VarChar(255)
  source_bigcommerce_product_id   BigInt?
  target_bigcommerce_product_id   BigInt?
  status                          PendingRelatedLinkStatus @default(PENDING)
  retry_count                     Int                      @default(0)
  last_error                      String?
  metadata                        Json                     @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  created_at                      DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime                 @default(now()) @db.Timestamptz(6)
  resolved_at                     DateTime?                @db.Timestamptz(6)
  vendor                          Vendor                   @relation(fields: [vendor_id], references: [vendor_id], onDelete: Cascade)

  @@unique([vendor_id, source_vendor_product_id, target_vendor_product_id])
  @@index([vendor_id, status])
  @@map("pending_related_product_link")
}

model ProductEnrichmentRetry {
  product_enrichment_retry_id BigInt                @id @default(autoincrement())
  vendor_id                   Int
  vendor_product_id           String                @db.VarChar(255)
  source                      EnrichmentSource
  status                      EnrichmentRetryStatus @default(PENDING)
  retry_count                 Int                   @default(0)
  last_error                  String?
  metadata                    Json                  @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  next_retry_at               DateTime?             @db.Timestamptz(6)
  created_at                  DateTime              @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime              @default(now()) @db.Timestamptz(6)
  resolved_at                 DateTime?             @db.Timestamptz(6)
  vendor                      Vendor                @relation(fields: [vendor_id], references: [vendor_id], onDelete: Cascade)

  @@unique([vendor_id, vendor_product_id, source])
  @@index([vendor_id, status, source])
  @@map("product_enrichment_retry")
}
