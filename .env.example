# BigCommerce app credentials from Developer Portal
# https://developer.bigcommerce.com/api-docs/apps/quick-start#register-a-draft-app
CLIENT_ID=
CLIENT_SECRET=
ACCOUNT_UUID=

# OAuth callback: BigCommerce redirects here after app authorization.
# Local: use your ngrok HTTPS URL, e.g. https://abc123.ngrok.io/api/auth
# Production: use deployed app URL from VendorsAppStack output "AppUrl", e.g. https://d1a2b3c.cloudfront.net/api/auth
# Must match the Auth Callback URL configured in the BigCommerce app in Developer Portal.
AUTH_CALLBACK=https://<app_url>/api/auth

# Database: for local dev, get username/password from AWS Secrets Manager.
# Secret name: bc-vendorsAuroraClusterCredentials
# Run: aws secretsmanager get-secret-value --secret-id bc-vendorsAuroraClusterCredentials --query SecretString --output text
# Then: postgresql://USERNAME:PASSWORD@HOST:5432/bcvendors
# HOST = RDS instance or proxy endpoint from AuroraStack outputs (see cdk-app/docs/DEPLOY-SETUP.md)
DATABASE_URL=postgresql://<username>:<password>@<host>:5432/vendors

# 32+ character random secret for JWT
JWT_KEY=

# Optional: token for server-side migrations. When set, POST /api/migrate with header x-migrate-token: <value> to run migrations on the server (no bastion needed). Deploy with -c migrateSecret=your-token to set in Lambda.
# MIGRATE_SECRET=

ENVIRONMENT=bigcommerce.com
LOGIN_URL=login.${ENVIRONMENT}
API_URL=api.${ENVIRONMENT}
